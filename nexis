#!/usr/bin/env bash
OR='\033[38;5;208m';GN='\033[38;5;70m';RD='\033[38;5;160m'
DIM='\033[2m';BOLD='\033[1m';RST='\033[0m'
SOCK="/run/nexis/nexis.sock"
SVC="nexis-controller"

_sigil(){
  echo -e "${OR}${BOLD}"
  cat << 'SIG'
                    .
                   /|\
                  / | \
                 /  |  \
                / . | . \
               /  (   )  \
              /  '  ◉  '  \
             /   '.   .'   \
            /     '---'     \
           /_________________\

      ███╗   ██╗███████╗██╗  ██╗██╗███████╗
      ████╗  ██║██╔════╝╚██╗██╔╝██║██╔════╝
      ██╔██╗ ██║█████╗   ╚███╔╝ ██║███████╗
      ██║╚██╗██║██╔══╝   ██╔██╗ ██║╚════██║
      ██║ ╚████║███████╗██╔╝ ██╗██║███████║
      ╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝╚═╝╚══════╝

      N e X i S
SIG
  echo -e "${RST}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status|-s)
      echo ""
      systemctl is-active "$SVC" &>/dev/null \
        && echo -e "  ${GN}●${RST} daemon   active" \
        || echo -e "  ${RD}●${RST} daemon   offline"
      curl -sfk https://localhost:8443/ -o /dev/null \
        && echo -e "  ${GN}●${RST} web      https://localhost:8443" \
        || echo -e "  ${RD}●${RST} web      offline"
      echo ""; exit 0;;
    --start)   sudo systemctl start   "$SVC" && echo -e "${GN}  started.${RST}"   || echo -e "${RD}  failed.${RST}"; exit 0;;
    --stop)    sudo systemctl stop    "$SVC" && echo -e "${GN}  stopped.${RST}"   || echo -e "${RD}  failed.${RST}"; exit 0;;
    --restart) sudo systemctl restart "$SVC" && echo -e "${GN}  restarted.${RST}" || echo -e "${RD}  failed.${RST}"; exit 0;;
    --logs)
      N="${2:-50}"; shift 2>/dev/null || true
      journalctl -u "$SVC" -n "$N" --no-pager; exit 0;;
    --web) xdg-open https://localhost:8443 2>/dev/null || echo "https://localhost:8443"; exit 0;;
    --setup-tls)
      DOMAIN="${2:-}"
      if [[ -z "$DOMAIN" ]]; then
        # Try to read EXTERNAL_DOMAIN from daemon script
        DAEMON_PY="$(dirname "$(readlink -f "$0")")/nexis_daemon.py"
        if [[ -f "$DAEMON_PY" ]]; then
          DOMAIN=$(grep -oP "(?<=EXTERNAL_DOMAIN = ')[^']+" "$DAEMON_PY" 2>/dev/null || true)
        fi
      fi
      if [[ -z "$DOMAIN" ]]; then
        echo -e "${RD}  Usage: nexis --setup-tls <your-domain.com>${RST}"
        echo -e "  ${DIM}e.g.  nexis --setup-tls nexis.toroag.ch${RST}"
        exit 1
      fi
      echo -e "\n  ${OR}${BOLD}Setting up Let's Encrypt TLS for: ${DOMAIN}${RST}"
      echo -e "  ${DIM}Make sure port 80 is forwarded to this machine.${RST}\n"
      # Install certbot if needed
      if ! command -v certbot &>/dev/null; then
        echo -e "  ${DIM}Installing certbot…${RST}"
        sudo apt-get install -y certbot 2>&1 | tail -5
      fi
      # Stop nexis so certbot can use port 80
      echo -e "  ${DIM}Stopping nexis temporarily…${RST}"
      sudo systemctl stop "$SVC" 2>/dev/null || true
      # Acquire cert
      echo -e "  ${DIM}Acquiring certificate from Let's Encrypt…${RST}"
      sudo certbot certonly --standalone \
        --non-interactive --agree-tos \
        --register-unsafely-without-email \
        -d "$DOMAIN" || {
          echo -e "\n  ${RD}certbot failed.${RST}"
          echo -e "  ${DIM}Make sure port 80 is forwarded and ${DOMAIN} points to this machine.${RST}"
          sudo systemctl start "$SVC" 2>/dev/null || true
          exit 1
        }
      # Copy certs to nexis config dir (daemon runs as current user, may not read /etc/letsencrypt)
      CONF_DIR="${HOME}/.config/nexis"
      mkdir -p "$CONF_DIR"
      sudo cp "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem" "${CONF_DIR}/server.crt"
      sudo cp "/etc/letsencrypt/live/${DOMAIN}/privkey.pem"   "${CONF_DIR}/server.key"
      sudo chown "${USER}:${USER}" "${CONF_DIR}/server.crt" "${CONF_DIR}/server.key"
      chmod 644 "${CONF_DIR}/server.crt"
      chmod 600 "${CONF_DIR}/server.key"
      # Install renewal hook so cert stays fresh
      HOOK_DIR="/etc/letsencrypt/renewal-hooks/deploy"
      sudo mkdir -p "$HOOK_DIR"
      sudo tee "${HOOK_DIR}/nexis-controller.sh" > /dev/null << HOOK
#!/bin/bash
cp "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem" "${CONF_DIR}/server.crt"
cp "/etc/letsencrypt/live/${DOMAIN}/privkey.pem"   "${CONF_DIR}/server.key"
chown "${USER}:${USER}" "${CONF_DIR}/server.crt" "${CONF_DIR}/server.key"
chmod 644 "${CONF_DIR}/server.crt"
chmod 600 "${CONF_DIR}/server.key"
systemctl restart nexis-controller
HOOK
      sudo chmod +x "${HOOK_DIR}/nexis-controller.sh"
      # Restart nexis
      sudo systemctl start "$SVC"
      echo -e "\n  ${GN}${BOLD}Done!${RST} TLS certificate installed for ${DOMAIN}."
      echo -e "  ${DIM}Access: ${OR}https://${DOMAIN}:8443${RST}"
      echo -e "  ${DIM}Renewal hook installed — cert will auto-renew via certbot.${RST}\n"
      exit 0;;
    --help|-h)
      echo -e "\n  ${OR}${BOLD}NeXiS Controller${RST}"
      echo -e "  ${DIM}──────────────────────────────────${RST}"
      echo -e "  ${OR}nexis${RST}                         open interactive session"
      echo -e "  ${OR}nexis --status${RST}                service + web status"
      echo -e "  ${OR}nexis --start/stop/restart${RST}"
      echo -e "  ${OR}nexis --logs [n]${RST}              service journal"
      echo -e "  ${OR}nexis --web${RST}                   open web UI"
      echo -e "  ${OR}nexis --setup-tls [domain]${RST}    get Let's Encrypt cert for HTTPS\n"
      exit 0;;
    *) echo -e "${RD}  unknown: $1${RST}  (nexis --help)"; exit 1;;
  esac
  shift
done

[[ ! -S "$SOCK" ]] && echo -e "\n  ${RD}NeXiS not running.${RST}\n  ${DIM}nexis --start${RST}\n" && exit 1

if ! command -v socat &>/dev/null; then
  echo -e "${RD}  socat not found — install with: sudo apt-get install socat${RST}" >&2; exit 1
fi

clear; _sigil
MEM=$(free -h 2>/dev/null | awk '/^Mem:/{print $3"/"$2}')
LOAD=$(awk '{print $1}' /proc/loadavg 2>/dev/null)
echo -e "  ${DIM}────────────────────────────────────────────────────${RST}"
printf  "  ${DIM}host   ${RST}%-26s  ${DIM}load  ${RST}%s\n" "$(hostname -s)" "$LOAD"
printf  "  ${DIM}ram    ${RST}%s\n" "$MEM"
echo -e "  ${DIM}────────────────────────────────────────────────────${RST}\n"
exec socat - UNIX-CONNECT:"$SOCK"
